/* =========================
   10) Views (Effective access + convenience)
   ========================= */

CREATE OR ALTER VIEW sec.vUserBudgetEffectiveAccess
AS
WITH NodeAncestors AS (
    SELECT
        bn.BudgetNodeID AS DescendantNodeID,
        bn.BudgetNodeID AS AncestorNodeID
    FROM BudgetNode bn

    UNION ALL

    SELECT
        na.DescendantNodeID,
        bn.ParentBudgetNodeID
    FROM NodeAncestors na
    JOIN BudgetNode bn
        ON bn.BudgetNodeID = na.AncestorNodeID
    WHERE bn.ParentBudgetNodeID IS NOT NULL
)
SELECT
    b.BudgetID,
    b.BudgetNodeID,
    ba.PrincipalID,
    p.DisplayName,
    r.RoleName,
    'DirectBudget' AS AccessSource
FROM Budget b
JOIN sec.BudgetAccess ba ON ba.BudgetID = b.BudgetID
JOIN sec.Principal p     ON p.PrincipalID = ba.PrincipalID
JOIN sec.BudgetRole r    ON r.BudgetRoleID = ba.BudgetRoleID
WHERE ba.EffectiveEndDate IS NULL OR ba.EffectiveEndDate >= CONVERT(date, SYSUTCDATETIME())

UNION ALL

SELECT
    b.BudgetID,
    b.BudgetNodeID,
    bna.PrincipalID,
    p.DisplayName,
    r.RoleName,
    'InheritedFromNode' AS AccessSource
FROM Budget b
JOIN NodeAncestors na          ON na.DescendantNodeID = b.BudgetNodeID
JOIN sec.BudgetNodeAccess bna  ON bna.BudgetNodeID = na.AncestorNodeID
JOIN sec.Principal p           ON p.PrincipalID = bna.PrincipalID
JOIN sec.BudgetRole r          ON r.BudgetRoleID = bna.BudgetRoleID
WHERE bna.EffectiveEndDate IS NULL OR bna.EffectiveEndDate >= CONVERT(date, SYSUTCDATETIME());
GO

CREATE OR ALTER VIEW vCurrentBudgetAmounts
AS
SELECT
    b.BudgetID,
    bv.BudgetVersionID,
    bv.VersionNumber,
    bv.VersionLabel,
    dp.PeriodID,
    dp.PeriodLabel,
    bav.BilledCost,
    bav.EffectiveCost,
    bav.IsApproved,
    bav.ApprovedDate
FROM Budget b
JOIN BudgetVersion bv
    ON bv.BudgetID = b.BudgetID AND bv.IsCurrent = 1
JOIN BudgetAmountVersion bav
    ON bav.BudgetVersionID = bv.BudgetVersionID
JOIN DimPeriod dp
    ON dp.PeriodID = bav.PeriodID
WHERE bav.EffectiveToDate IS NULL;
GO

CREATE OR ALTER VIEW vCurrentForecastAmounts
AS
SELECT
    f.ForecastID,
    fv.ForecastVersionID,
    fv.VersionNumber,
    fv.VersionLabel,
    dp.PeriodID,
    dp.PeriodLabel,
    fav.BilledCost,
    fav.EffectiveCost
FROM Forecast f
JOIN ForecastVersion fv
    ON fv.ForecastID = f.ForecastID AND fv.IsCurrent = 1
JOIN ForecastAmountVersion fav
    ON fav.ForecastVersionID = fv.ForecastVersionID
JOIN DimPeriod dp
    ON dp.PeriodID = fav.PeriodID
WHERE fav.EffectiveToDate IS NULL;
GO

