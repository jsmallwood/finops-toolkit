CREATE OR ALTER PROCEDURE usp_ForecastVersion_SetCurrent
(
    @ForecastVersionID INT,
    @ChangedBy         NVARCHAR(100)
)
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    DECLARE @ForecastID INT;

    SELECT @ForecastID = ForecastID
    FROM ForecastVersion
    WHERE ForecastVersionID = @ForecastVersionID;

    IF (@ForecastID IS NULL)
        THROW 50003, 'Invalid ForecastVersionID.', 1;

    BEGIN TRAN;

    UPDATE ForecastVersion
    SET IsCurrent = 0
    WHERE ForecastID = @ForecastID
      AND IsCurrent = 1;

    UPDATE ForecastVersion
    SET IsCurrent = 1
    WHERE ForecastVersionID = @ForecastVersionID;

    COMMIT TRAN;
END
GO

CREATE OR ALTER PROCEDURE usp_ForecastVersion_Create
(
    @ForecastID            INT,
    @VersionLabel          VARCHAR(50),
    @ForecastMethod        VARCHAR(100) = NULL,
    @ChangeReason          VARCHAR(255) = NULL,
    @CreatedBy             NVARCHAR(100),
    @CloneFromCurrent      BIT = 1,
    @SetAsCurrent          BIT = 1,
    @NewForecastVersionID  INT OUTPUT
)
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    BEGIN TRAN;

    DECLARE @NextVersionNumber INT;

    SELECT @NextVersionNumber = ISNULL(MAX(VersionNumber), 0) + 1
    FROM ForecastVersion WITH (UPDLOCK, HOLDLOCK)
    WHERE ForecastID = @ForecastID;

    INSERT INTO ForecastVersion
    (
        ForecastID, VersionNumber, VersionLabel, ForecastMethod, ChangeReason,
        IsCurrent, CreatedBy, CreatedDate
    )
    VALUES
    (
        @ForecastID, @NextVersionNumber, @VersionLabel, @ForecastMethod, @ChangeReason,
        0, @CreatedBy, SYSUTCDATETIME()
    );

    SET @NewForecastVersionID = SCOPE_IDENTITY();

    IF (@CloneFromCurrent = 1)
    BEGIN
        DECLARE @CurrentForecastVersionID INT;

        SELECT @CurrentForecastVersionID = ForecastVersionID
        FROM ForecastVersion
        WHERE ForecastID = @ForecastID AND IsCurrent = 1;

        IF (@CurrentForecastVersionID IS NOT NULL)
        BEGIN
            INSERT INTO ForecastAmountVersion
            (
                ForecastVersionID, PeriodID, BilledCost, EffectiveCost,
                EffectiveFromDate, EffectiveToDate
            )
            SELECT
                @NewForecastVersionID,
                fav.PeriodID,
                fav.BilledCost,
                fav.EffectiveCost,
                SYSUTCDATETIME(),
                NULL
            FROM ForecastAmountVersion fav
            WHERE fav.ForecastVersionID = @CurrentForecastVersionID
              AND fav.EffectiveToDate IS NULL;
        END
    END

    IF (@SetAsCurrent = 1)
    BEGIN
        EXEC usp_ForecastVersion_SetCurrent
            @ForecastVersionID = @NewForecastVersionID,
            @ChangedBy = @CreatedBy;
    END

    COMMIT TRAN;
END
GO

