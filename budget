   12) Stored Procedures: Version Management (Budgets)
   ========================= */

CREATE OR ALTER PROCEDURE usp_BudgetVersion_SetCurrent
(
    @BudgetVersionID INT,
    @ChangedBy       NVARCHAR(100)
)
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    DECLARE @BudgetID INT;

    SELECT @BudgetID = BudgetID
    FROM BudgetVersion
    WHERE BudgetVersionID = @BudgetVersionID;

    IF (@BudgetID IS NULL)
        THROW 50001, 'Invalid BudgetVersionID.', 1;

    BEGIN TRAN;

    UPDATE BudgetVersion
    SET IsCurrent = 0
    WHERE BudgetID = @BudgetID
      AND IsCurrent = 1;

    UPDATE BudgetVersion
    SET IsCurrent = 1
    WHERE BudgetVersionID = @BudgetVersionID;

    COMMIT TRAN;
END
GO

CREATE OR ALTER PROCEDURE usp_BudgetVersion_Create
(
    @BudgetID            INT,
    @VersionLabel        VARCHAR(50),
    @ChangeReason        VARCHAR(255) = NULL,
    @CreatedBy           NVARCHAR(100),
    @CloneFromCurrent    BIT = 1,
    @SetAsCurrent        BIT = 1,
    @NewBudgetVersionID  INT OUTPUT
)
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    BEGIN TRAN;

    DECLARE @NextVersionNumber INT;

    SELECT @NextVersionNumber = ISNULL(MAX(VersionNumber), 0) + 1
    FROM BudgetVersion WITH (UPDLOCK, HOLDLOCK)
    WHERE BudgetID = @BudgetID;

    INSERT INTO BudgetVersion
    (
        BudgetID, VersionNumber, VersionLabel, ChangeReason, IsCurrent, CreatedBy, CreatedDate
    )
    VALUES
    (
        @BudgetID, @NextVersionNumber, @VersionLabel, @ChangeReason, 0, @CreatedBy, SYSUTCDATETIME()
    );

    SET @NewBudgetVersionID = SCOPE_IDENTITY();

    IF (@CloneFromCurrent = 1)
    BEGIN
        DECLARE @CurrentBudgetVersionID INT;

        SELECT @CurrentBudgetVersionID = BudgetVersionID
        FROM BudgetVersion
        WHERE BudgetID = @BudgetID AND IsCurrent = 1;

        IF (@CurrentBudgetVersionID IS NOT NULL)
        BEGIN
            INSERT INTO BudgetAmountVersion
            (
                BudgetVersionID, PeriodID, BilledCost, EffectiveCost,
                IsApproved, ApprovedByPrincipalID, ApprovedDate,
                EffectiveFromDate, EffectiveToDate
            )
            SELECT
                @NewBudgetVersionID,
                bav.PeriodID,
                bav.BilledCost,
                bav.EffectiveCost,
                0, NULL, NULL,
                SYSUTCDATETIME(),
                NULL
            FROM BudgetAmountVersion bav
            WHERE bav.BudgetVersionID = @CurrentBudgetVersionID
              AND bav.EffectiveToDate IS NULL;
        END
    END

    IF (@SetAsCurrent = 1)
    BEGIN
        EXEC usp_BudgetVersion_SetCurrent
            @BudgetVersionID = @NewBudgetVersionID,
            @ChangedBy = @CreatedBy;
    END

    COMMIT TRAN;
END
GO

CREATE OR ALTER PROCEDURE usp_BudgetAmount_UpsertCurrent
(
    @BudgetID     INT,
    @Amounts      BudgetAmountTvp READONLY,
    @ChangedBy    NVARCHAR(100)
)
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    DECLARE @BudgetVersionID INT = NULL;
    DECLARE @Now DATETIME2 = SYSUTCDATETIME();

    SELECT @BudgetVersionID = BudgetVersionID
    FROM BudgetVersion
    WHERE BudgetID = @BudgetID AND IsCurrent = 1;

    IF (@BudgetVersionID IS NULL)
        THROW 50002, 'No current BudgetVersion exists for this BudgetID.', 1;

    BEGIN TRAN;

    /* Close changed rows */
    UPDATE bav
    SET EffectiveToDate = @Now
    FROM BudgetAmountVersion bav
    JOIN @Amounts a
      ON a.PeriodID = bav.PeriodID
    WHERE bav.BudgetVersionID = @BudgetVersionID
      AND bav.EffectiveToDate IS NULL
      AND (
            ISNULL(bav.BilledCost, -999999999.9999) <> ISNULL(a.BilledCost, -999999999.9999)
         OR ISNULL(bav.EffectiveCost, -999999999.9999) <> ISNULL(a.EffectiveCost, -999999999.9999)
      );

    /* Insert new rows where missing or changed */
    INSERT INTO BudgetAmountVersion
    (
        BudgetVersionID, PeriodID, BilledCost, EffectiveCost,
        IsApproved, ApprovedByPrincipalID, ApprovedDate,
        EffectiveFromDate, EffectiveToDate
    )
    SELECT
        @BudgetVersionID,
        a.PeriodID,
        a.BilledCost,
        a.EffectiveCost,
        0, NULL, NULL,
        @Now,
        NULL
    FROM @Amounts a
    LEFT JOIN BudgetAmountVersion bav
      ON bav.BudgetVersionID = @BudgetVersionID
     AND bav.PeriodID = a.PeriodID
     AND bav.EffectiveToDate IS NULL
    WHERE bav.BudgetAmountVersionID IS NULL
       OR (
            ISNULL(bav.BilledCost, -999999999.9999) <> ISNULL(a.BilledCost, -999999999.9999)
         OR ISNULL(bav.EffectiveCost, -999999999.9999) <> ISNULL(a.EffectiveCost, -999999999.9999)
       );

    COMMIT TRAN;
END
GO

CREATE OR ALTER PROCEDURE usp_BudgetAmount_Approve
(
    @BudgetVersionID       INT,
