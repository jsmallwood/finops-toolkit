    EXEC('CREATE SCHEMA finops AUTHORIZATION dbo;');
GO

IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name = 'sec')
    EXEC('CREATE SCHEMA sec AUTHORIZATION dbo;');
GO

/* =========================
   2) Core Dimensions
   ========================= */

IF OBJECT_ID('DimPeriod','U') IS NULL
BEGIN
    CREATE TABLE DimPeriod (
        PeriodID          INT IDENTITY(1,1) PRIMARY KEY,
        PeriodStartDate   DATE NOT NULL,
        PeriodEndDate     DATE NOT NULL,
        PeriodLabel       VARCHAR(50) NOT NULL,   -- e.g. 2026-01
        PeriodType        VARCHAR(20) NOT NULL    -- Monthly, Quarterly, Annual, Daily
    );

    CREATE INDEX IX_DimPeriod_StartEnd ON DimPeriod(PeriodStartDate, PeriodEndDate);
    CREATE UNIQUE INDEX UX_DimPeriod_LabelType ON DimPeriod(PeriodLabel, PeriodType);
END
GO

/* =========================
   3) Budget Hierarchy
   ========================= */

IF OBJECT_ID('BudgetHierarchy','U') IS NULL
BEGIN
    CREATE TABLE BudgetHierarchy (
        BudgetHierarchyID  INT IDENTITY(1,1) PRIMARY KEY,
        Name               VARCHAR(100) NOT NULL,
        Description        VARCHAR(255) NULL,
        IsActive           BIT NOT NULL CONSTRAINT DF_BudgetHierarchy_IsActive DEFAULT 1,
        CreatedDate        DATETIME2 NOT NULL CONSTRAINT DF_BudgetHierarchy_CreatedDate DEFAULT SYSUTCDATETIME()
    );

    CREATE UNIQUE INDEX UX_BudgetHierarchy_Name ON BudgetHierarchy(Name);
END
GO

IF OBJECT_ID('BudgetNode','U') IS NULL
BEGIN
    CREATE TABLE BudgetNode (
        BudgetNodeID          INT IDENTITY(1,1) PRIMARY KEY,
        BudgetHierarchyID     INT NOT NULL,
        ParentBudgetNodeID    INT NULL,

        NodeType              VARCHAR(50) NOT NULL,     -- Organization, Portfolio, Application, Environment, CostCenter, Subscription, etc.
        NodeKey               VARCHAR(200) NOT NULL,    -- stable key
        NodeName              VARCHAR(200) NOT NULL,    -- display

        EffectiveStartDate    DATE NOT NULL,
        EffectiveEndDate      DATE NULL,

        CONSTRAINT FK_BudgetNode_Hierarchy
            FOREIGN KEY (BudgetHierarchyID)
            REFERENCES BudgetHierarchy(BudgetHierarchyID),

        CONSTRAINT FK_BudgetNode_Parent
            FOREIGN KEY (ParentBudgetNodeID)
            REFERENCES BudgetNode(BudgetNodeID),

        CONSTRAINT CK_BudgetNode_EffectiveDates
            CHECK (EffectiveEndDate IS NULL OR EffectiveEndDate >= EffectiveStartDate)
    );

    CREATE INDEX IX_BudgetNode_HierarchyParent ON BudgetNode(BudgetHierarchyID, ParentBudgetNodeID);
    CREATE UNIQUE INDEX UX_BudgetNode_HierarchyKeyDates
        ON BudgetNode(BudgetHierarchyID, NodeKey, EffectiveStartDate);
END
GO

